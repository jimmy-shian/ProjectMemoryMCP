{
  "project": {
    "root": ".",
    "memory_dir": ".project-memory"
  },
  "database": {
    "path": ".project-memory/project_knowledge.db",
    "echo": false
  },
  "transport": "stdio",
  "llm": {
    "mode": "server_driven",
    "provider": "myself",
    "api_key": "not-needed",
    "model": "patcher-main",
    "api_base": "http://localhost:4000/v1",
    "temperature": 0.1
  },
  "analysis": {
    "use_vector_similarity": false,
    "max_analysis_depth": 3
  },
  "safety": {
    "require_impact_analysis_before_edit": true,
    "require_confirmation_before_delete": true,
    "preserve_comments": true,
    "preserve_commented_code": true
  },
  "exclude_patterns": [
    ".git",
    "node_modules",
    "__pycache__",
    ".venv",
    "venv",
    "env",
    "build",
    "dist",
    "target",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    "*.egg-info",
    ".tox",
    ".idea",
    ".vscode",
    "*.pyc",
    "*.pyo",
    "*.pyd",
    "*.so",
    "*.dll",
    "*.exe",
    "*.bin",
    "*.obj",
    "*.o",
    "*.a",
    "*.lib",
    "*.jar",
    "*.war",
    "*.ear",
    "*.class",
    ".DS_Store",
    "Thumbs.db",
    "*.log",
    "*.tmp",
    "*.temp",
    "*.swp",
    "*.swo",
    "*~"
  ],
  "languages": [
    "python",
    "typescript",
    "javascript",
    "rust",
    "go",
    "java",
    "c",
    "cpp"
  ],
  "workflow": {
    "auto_index": true,
    "auto_build_graph": true,
    "auto_generate_manual": true
  }
}
